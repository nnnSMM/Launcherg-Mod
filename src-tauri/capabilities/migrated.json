{
  "identifier": "migrated",
  "description": "permissions that were migrated from v1",
  "local": true,
  "windows": [
    "main",
    "screenshot_window",
    "tray_menu"
  ],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-stat",
    {
      "identifier": "fs:scope",
      "allow": [
        "**"
      ]
    },
    "shell:allow-open",
    "dialog:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://erogamescape.dyndns.org/~ap2/ero/toukei_kaiseki/*"
        },
        {
          "url": "https://dlsoft.dmm.com/detail/*"
        },
        {
          "url": "https://www.dlsite.com/*"
        },
        {
          "url": "https://store.steampowered.com/app/*"
        },
        {
          "url": "https://seiya-saiga.com/game/*"
        },
        {
          "url": "https://raw.githubusercontent.com/ryoha000/launcherg/*"
        },
        {
          "url": "https://launcherg.ryoha.moe/*"
        },
        {
          "url": "http://localhost:3248/*"
        }
      ]
    },
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-read-image",
    "clipboard-manager:default",
    "fs:default",
    "dialog:default",
    "shell:default",
    "http:default",
    "shell:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    "global-shortcut:allow-is-registered",
    "autostart:default",
    "window-state:default"
  ]
}
